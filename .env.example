# Copy to .env and fill in real values. Never commit .env.

# Local Express / CRA proxy target
REACT_APP_API_URL=http://localhost:3001

# OpenWeatherMap (https://openweathermap.org/api)
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: set to true to enable Firebase Analytics in the browser
REACT_APP_ENABLE_ANALYTICS=false

# Server only (Express). Prefer this over a local JSON file in production.
# Paste the full service account JSON as a single line, or set via hosting env.
# FIREBASE_SERVICE_ACCOUNT_JSON=
