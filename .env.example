# Copy to .env and fill in real values. Never commit .env.

# Local Express / CRA proxy target
REACT_APP_API_URL=http://localhost:3001

# OpenWeatherMap (https://openweathermap.org/api)
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: set to true to enable Firebase Analytics in the browser
REACT_APP_ENABLE_ANALYTICS=false

# Server only (Express). Prefer env var in production over a local JSON file.
# Option A: paste the full service account JSON as a single line
# FIREBASE_SERVICE_ACCOUNT_JSON=
#
# Option B (local dev): save the downloaded Firebase key as serviceAccountKey.json
# in the project root (gitignored). Do not commit the JSON file itself.
